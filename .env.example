# ── PostgreSQL ──────────────────────────────────────────────
PG_USER=postgres
PG_PASSWORD=postgres

# ── Auth Service ────────────────────────────────────────────
# JWT secret cho dev (HS256) — đổi thành chuỗi dài >= 32 ký tự
JWT_SECRET=change-me-in-production-must-be-32-chars!
JWT_ALGORITHM=HS256

# Nếu dùng RS256 (production):
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY_PATH=/keys/private.pem
# JWT_PUBLIC_KEY_PATH=/keys/public.pem

# ── SSO (Stage 2, chưa dùng) ─────────────────────────────────
AUTH_SSO_ENABLED=false
